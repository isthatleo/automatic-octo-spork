# Backend configuration
HOST=0.0.0.0
PORT=8000
WS_PATH=/ws

# STT
STT_BACKEND=faster_whisper   # options: faster_whisper, openai_whisper, mlx
WHISPER_MODEL=tiny.en        # or small, medium, large
WHISPER_DEVICE=cpu           # cuda, cpu, or mlx (for Apple Silicon)

# LLM
# Order of preference: first working backend in the list will be used.
# Available options: dummy, llama_cpp, ollama, anthropic, openai, gemini, openrouter, groq
LLM_BACKENDS=dummy,ollama,anthropic,openai,gemini,openrouter,groq
# For LlamaCpp
LLM_MODEL_PATH=/path/to/phi-3.Q4_K_M.gguf
LLM_N_CTX=4096
LLM_N_BATCH=512
LLM_N_GPU_LAYERS=0           # set >0 for GPU acceleration if supported

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Groq
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# TTS
# options: neutts (real local neural voice via fury-sdk's NeuTTS-nano, CPU-only,
#   see neu_tts.py — default), pyttsx3 (Windows SAPI, robotic, kept as a fallback)
TTS_BACKEND=neutts
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_SPEAKER=
TTS_LANGUAGE=en
TTS_USE_CUDA=False

# NeuTTS voice-cloning reference clip. Checked in this order:
#   1. voice_ref/user_reference.wav + user_reference.txt  <- drop your own clip + its transcript here, then restart the backend
#   2. voice_ref/synthetic_reference.wav + .txt            <- auto-bootstrapped via the Pyttsx3 "Hazel" voice if neither exists
VOICE_REF_DIR=./voice_ref
# phonemizer (a NeuTTS dependency) needs the espeak-ng system library on PATH.
# On Windows: winget install eSpeak-NG.eSpeak-NG (or the official installer),
# then point these at its install dir if it isn't auto-detected:
# PHONEMIZER_ESPEAK_LIBRARY=C:\Program Files\eSpeak NG\libespeak-ng.dll
# PHONEMIZER_ESPEAK_PATH=C:\Program Files\eSpeak NG\espeak-ng.exe

# PersonaPlex (optional)
PERSONAPLEX_ENABLED=False
PERSONAPLEX_MODEL=nvidia/personaplex-7b-v1
PERSONAPLEX_VOICE_PROMPT=assets/voice_prompt.pt   # path to .pt embedding
PERSONAPLEX_DEVICE=cpu

# Open Generative AI (tool)
OPENAI_GENERATIVE_API_URL=http://localhost:3000/api/generate   # if using local OGAI service
OPENAI_GENERATIVE_API_KEY=

# MiroFish (tool)
MIROFISH_API_URL=http://localhost:5001/api
MIROFISH_API_KEY=

# Memory
MEMORY_DB_PATH=./data/memory.sqlite

# Logging
LOG_LEVEL=INFO