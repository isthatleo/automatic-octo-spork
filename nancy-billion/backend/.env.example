# Backend configuration
HOST=0.0.0.0
PORT=8000
WS_PATH=/ws

# Comma-separated origins the browser is allowed to call this API from.
# Must match the frontend's actual dev port -- this project runs
# `next dev -p 3005`, not Next's default 3000.
NANCY_ALLOWED_ORIGINS=http://localhost:3005,http://127.0.0.1:3005

# STT
STT_BACKEND=faster_whisper   # options: faster_whisper, openai_whisper, mlx
WHISPER_MODEL=tiny.en        # or small, medium, large
WHISPER_DEVICE=cpu           # cuda, cpu, or mlx (for Apple Silicon)

# LLM
# get_llm_backends() in llm.py builds the real priority order: cloud backends
# first (best quality, in the order below), then local Ollama as an offline
# fallback, then Fury. LLM_BACKENDS below only affects a legacy secondary
# list (dummy/llama_cpp/ollama) appended after that -- not the main ordering.
LLM_BACKENDS=dummy,ollama,anthropic,openai,gemini,openrouter,groq
# For LlamaCpp
LLM_MODEL_PATH=/path/to/phi-3.Q4_K_M.gguf
LLM_N_CTX=4096
LLM_N_BATCH=512
LLM_N_GPU_LAYERS=0           # set >0 for GPU acceleration if supported

# Ollama (free, local, offline fallback -- install from ollama.com, then
# `ollama pull llama3.2:3b` or similar; pick a small model on CPU-only hardware)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# Coding-task fallback model (see select_llm_for_task) -- `ollama pull qwen2.5-coder:3b`
OLLAMA_CODING_MODEL=qwen2.5-coder:3b

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Gemini (Google) -- check https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY
# for currently-supported model ids; "gemini-pro" alone was retired.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro-latest

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Groq -- check https://console.groq.com/docs/deprecations for currently-supported models.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenCode Zen (coding-focused model gateway, https://opencode.ai/zen) -- sign
# in at opencode.ai, add billing, copy your API key here. Model ids are bare
# (e.g. "big-pickle", "gpt-5.5") -- confirm against GET /v1/models.
OPENCODE_API_KEY=
OPENCODE_MODEL=big-pickle

# TTS
# options: neutts (real local neural voice via fury-sdk's NeuTTS-nano, CPU-only,
#   see neu_tts.py — default), pyttsx3 (Windows SAPI, robotic, kept as a fallback)
TTS_BACKEND=neutts
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_SPEAKER=
TTS_LANGUAGE=en
TTS_USE_CUDA=False

# NeuTTS voice-cloning reference clip. Checked in this order:
#   1. voice_ref/user_reference.wav + user_reference.txt  <- drop your own clip + its transcript here, then restart the backend
#   2. voice_ref/synthetic_reference.wav + .txt            <- auto-bootstrapped via the Pyttsx3 "Hazel" voice if neither exists
VOICE_REF_DIR=./voice_ref
# phonemizer (a NeuTTS dependency) needs the espeak-ng system library on PATH.
# On Windows: winget install eSpeak-NG.eSpeak-NG (or the official installer),
# then point these at its install dir if it isn't auto-detected:
# PHONEMIZER_ESPEAK_LIBRARY=C:\Program Files\eSpeak NG\libespeak-ng.dll
# PHONEMIZER_ESPEAK_PATH=C:\Program Files\eSpeak NG\espeak-ng.exe

# PersonaPlex (optional)
PERSONAPLEX_ENABLED=False
PERSONAPLEX_MODEL=nvidia/personaplex-7b-v1
PERSONAPLEX_VOICE_PROMPT=assets/voice_prompt.pt   # path to .pt embedding
PERSONAPLEX_DEVICE=cpu

# Open Generative AI (tool)
OPENAI_GENERATIVE_API_URL=http://localhost:3000/api/generate   # if using local OGAI service
OPENAI_GENERATIVE_API_KEY=

# MiroFish (tool)
MIROFISH_API_URL=http://localhost:5001/api
MIROFISH_API_KEY=

# Memory
MEMORY_DB_PATH=./data/memory.sqlite

# Telegram (remote notifications/approvals -- see telegram_bot.py)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Proactive daily briefing pushed to Telegram automatically, no request
# needed -- 24h local time (see _daily_briefing_loop in main_new.py)
DAILY_BRIEFING_HOUR=7
DAILY_BRIEFING_MINUTE=30

# FRED (St. Louis Fed) -- powers live NFP/CPI/FOMC tracking
# (economic_calendar.py). Free, instant self-serve key:
# https://fred.stlouisfed.org/docs/api/api_key.html
# (Financial Modeling Prep was tried first, but its economic-calendar
# endpoint turned out to require a paid plan once tested against a real
# account -- confirmed via direct probe, not assumed. FRED has real actual
# release dates/values for NFP+CPI and no rate-limit concern at this
# polling cadence, but no consensus/forecast data -- estimate is always
# null.) Without this set, the economic calendar feature is silently
# disabled (logs a warning once, /economic-calendar/events returns an
# empty list, "configured": false).
FRED_API_KEY=

# Logging
LOG_LEVEL=INFO