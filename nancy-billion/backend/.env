# Backend configuration
HOST=0.0.0.0
PORT=8000
WS_PATH=/ws

# STT
STT_BACKEND=faster_whisper
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
# Force British English transcription. Acceptable values: en, en-GB, en-US, etc.
STT_LANGUAGE=en-GB

# LLM
# Order of preference: first working backend in the list will be used.
# Available options: dummy, llama_cpp, ollama, anthropic, openai, gemini, openrouter, groq
LLM_BACKENDS=ollama,anthropic,openai,gemini,openrouter,groq
# For LlamaCpp
LLM_MODEL_PATH=/path/to/phi-3.Q4_K_M.gguf
LLM_N_CTX=4096
LLM_N_BATCH=512
LLM_N_GPU_LAYERS=0           # set >0 for GPU acceleration if supported

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Groq
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# TTS
TTS_BACKEND=pyttsx3
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_SPEAKER=
TTS_LANGUAGE=en-GB
TTS_USE_CUDA=False
# Force a British female voice. On Windows SAPI this resolves to "Microsoft Hazel".
# Set to empty string to fall back to the auto-detection heuristic.
TTS_VOICE_NAME=Microsoft Hazel

# PersonaPlex (optional)
PERSONAPLEX_ENABLED=False
PERSONAPLEX_MODEL=nvidia/personaplex-7b-v1
PERSONAPLEX_VOICE_PROMPT=assets/voice_prompt.pt
PERSONAPLEX_DEVICE=cpu

# Open Generative AI (tool)
OPENAI_GENERATIVE_API_URL=http://localhost:3000/api/generate
OPENAI_GENERATIVE_API_KEY=

# MiroFish (tool)
MIROFISH_API_URL=http://localhost:5001/api
MIROFISH_API_KEY=

# Memory
MEMORY_DB_PATH=./data/memory.sqlite

# Logging
LOG_LEVEL=INFO