# Nancy/Billion Backend — Environment Configuration Template
# Copy this file to .env and update with your actual values

# ============ OLLAMA (Local LLM) ============
# Ollama provides fast, local LLM inference
# Download from: https://ollama.ai
# Start with: ollama serve
#
# No GPU on this machine: stick to small quantized models. Recommended first pull:
#   ollama pull llama3.2:3b
# Other CPU-friendly options: qwen2.5:3b-instruct, phi3.5
OLLAMA_BASE_URL=http://localhost:11434
# Models are auto-detected; set OLLAMA_MODEL to prefer a specific one
# OLLAMA_MODEL=llama3.2:3b

# Disable auto-detection of Ollama models (set to 1 to disable)
# DISABLE_AUTO_OLLAMA=0

# ============ ANTHROPIC (Claude) ============
# Claude is excellent for coding, complex reasoning, and writing.
# Uses the official `anthropic` Python SDK (see backend/llm.py AnthropicLLM).
# Get API key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# claude-opus-4-8: current top-tier model, best for coding/self-improvement agents.
# Swap to claude-sonnet-5 for a cheaper/faster default on general chat if desired.
ANTHROPIC_MODEL=claude-opus-4-8

# ============ GROQ (Fastest Cloud Inference) ============
# Lightning-fast LLM inference with free tier
# Get API key: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxx
GROQ_MODEL=mixtral-8x7b-32768

# ============ OPENAI (GPT Models) ============
# General-purpose LLM, widely trusted
# Get API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview

# ============ GEMINI (Google) ============
# Multimodal support (vision + text)
# Get API key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxx
GEMINI_MODEL=gemini-pro

# ============ OPENROUTER (Multi-Model Aggregator) ============
# Access 200+ models through a single API
# Get API key: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx
OPENROUTER_MODEL=openrouter/auto

# ============ FURY (Optional AI Agent Framework) ============
# Set to 1 to disable Fury integration if not installed
# DISABLE_FURY=0

# ============ LLAMA.CPP (Local GGUF Models) ============
# For running GGUF quantized models locally
# LLM_MODEL_PATH=/path/to/model.gguf
# LLM_N_CTX=4096
# LLM_N_BATCH=512
# LLM_N_GPU_LAYERS=0

# ============ BACKEND SERVER ============
HOST=0.0.0.0
PORT=8000

# ============ SECURITY ============
# Comma-separated list of allowed frontend origins (CORS). No wildcard by default.
NANCY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional shared-secret auth for /chat, /agents/run, /agents/auto, /trading/*,
# and the /ws websocket (as ?token=... query param). Leave unset for local-only
# dev; set it before exposing this backend beyond localhost (LAN, tunnel, etc.).
# BACKEND_AUTH_TOKEN=

# Simple per-IP rate limiting on the routes above.
BACKEND_RATE_LIMIT_MAX=30
BACKEND_RATE_LIMIT_WINDOW_S=60

# ============ LOGGING ============
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============ WEBSOCKET ============
# WS_PATH=/ws

# ============ HISTORY & PERSISTENCE ============
HISTORY_ROOT=./data/fury_history
HISTORY_SESSION_ID=nancybillion

# ============ LEGACY: Configure LLM backends via comma-separated list ============
# Only used if not set above; default chain is: Ollama → Anthropic → Groq → OpenAI → Gemini → OpenRouter
# Leave empty to use auto-detection (recommended)
# LLM_BACKENDS=ollama,anthropic,openai,dummy

# ============ BASE SYSTEM PROMPT (Optional override) ============
# Leave unset to use the default Nancy system prompt
# SYSTEM_PROMPT="You are Nancy, a sovereign AI assistant..."

# ============ FRONTEND COMMUNICATION ============
# Typically Nancy backend runs on :8000 and frontend on :3000
# Frontend connects to backend at this URL (set in frontend/.env)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ============ PRODUCTION SETTINGS ============
# For production deployments:
# - Set HOST to specific IP or domain
# - Use environment-specific secrets management
# - Enable authentication/authorization
# - Use proper certificate handling for TLS
# - Consider rate limiting and DDoS protection

